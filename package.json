{
  "name": "standupcraft",
  "version": "1.0.0",
  "description": "MCP server that reads git commits and GitHub activity to generate daily standups, weekly client reports, and sprint retros",
  "type": "module",
  "bin": {
    "standupcraft": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "standup",
    "daily-standup",
    "git",
    "github",
    "developer-tools",
    "productivity",
    "freelance",
    "status-report"
  ],
  "author": "Mat Carter",
  "license": "MIT",
  "homepage": "https://github.com/jabbawocky/standupcraft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jabbawocky/standupcraft.git"
  },
  "bugs": {
    "url": "https://github.com/jabbawocky/standupcraft/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@octokit/rest": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
